# ── Cloud / Auth ─────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Agent model ──────────────────────────────────────────
AGENT_MODEL=gemini-2.5-flash-lite

# ── Database ───────────────────────────────────────────────
# DB_TYPE: "mssql" for SQL Server (postgres support removed)
DB_TYPE=mssql

# SQL Server settings
DB_HOST=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
# Optional: load password from Secret Manager instead of DB_PASSWORD.
# Format: projects/PROJECT_ID/secrets/SECRET_NAME/versions/latest
DB_PASSWORD_SECRET=
# Local dev: use Docker VPN tunnel. Cloud Run: set to yisbeta_relay_vm via Cloud Run env vars.
DB_DEFAULT_ALIAS=yisbeta_tunnel

# ── Text-to-SQL guardrails ───────────────────────────────
TEXT_TO_SQL_ALLOWED_TABLES=orders,customers,products,order_items
TEXT_TO_SQL_MAX_ROWS=200
TEXT_TO_SQL_QUERY_TIMEOUT_MS=15000

# ── PII masking ──────────────────────────────────────────
PII_MASKING_ENABLED=true
PII_USE_PRESIDIO=false
PII_DEFAULT_RULES=name,ssn,email

# ── RAG (Vertex AI RAG Engine) ───────────────────────────
# Leave empty to disable document search; set to enable:
# VERTEX_RAG_CORPUS=projects/PROJECT/locations/REGION/ragCorpora/CORPUS_ID
VERTEX_RAG_CORPUS=

# ── Tenant config (future multi-tenant) ──────────────────
TENANT_CONFIG_USE_FIRESTORE=false
TENANT_DEFAULT_DB_TYPE=postgres
TENANT_DEFAULT_SECRET_NAME=
# ── Auth (Firebase Google Sign-In) ────────────────────────────
# Set AUTH_DISABLED=true to skip Firebase token validation (local dev without auth)
AUTH_DISABLED=false
# Firebase project ID (used by firebase-admin on the backend)
FIREBASE_PROJECT_ID=ayra-sales-assistant-490010

# ── Support Agent (GitHub integration) ─────────────────────────
# Secret Manager path to the GitHub PAT (repo scope) used by the Support Agent.
# Default value is set in src/support_agent/agent.py.
# GITHUB_PAT_SECRET=projects/ayra-sales-assistant-490010/secrets/github-support-agent-pat/versions/latest
# For local dev you can set the PAT directly (never commit this value):
# GITHUB_PAT=ghp_...